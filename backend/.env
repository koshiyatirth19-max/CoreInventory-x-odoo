PORT=5000

# ── Local MongoDB (required) ─────────────────────────────────
# Install MongoDB Community Server: https://www.mongodb.com/try/download/community
# Start it with: mongod --dbpath /data/db
# No account or internet needed — runs entirely on your machine.
MONGO_URI=mongodb://127.0.0.1:27017/coreinventory

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=coreinventory_super_secret_change_me
JWT_EXPIRE=7d

# ── Frontend URL (for CORS) ──────────────────────────────────
CLIENT_URL=http://localhost:3000
